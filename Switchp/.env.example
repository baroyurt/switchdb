# Switchp — Environment Configuration
# Kopyala: .env.example → .env  (veya XAMPP httpd-env.conf'a ekle)
# ---------------------------------------------------------------

# Uygulama ortamı
APP_ENV=production

# MySQL bağlantı bilgileri
# Standalone MySQL kurulumunda DB_PORT=3307 yap
DB_HOST=127.0.0.1
DB_PORT=3306
DB_USER=root
DB_PASS=
DB_NAME=switchdb

# Log seviyesi: DEBUG | INFO | WARNING | ERROR
LOG_LEVEL=WARNING
