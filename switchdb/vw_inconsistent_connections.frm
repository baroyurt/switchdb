source=-- Port\'ta panel var ama panel\'de port yok\n            SELECT \n                \'port_has_panel_but_panel_missing\' as issue_type,\n                p.id as port_id,\n                p.switch_id,\n                p.port_no,\n                p.connected_panel_id,\n                p.connected_panel_port,\n                p.panel_type,\n                NULL as panel_port_id,\n                CONCAT(\'Switch \', s.name, \' Port \', p.port_no, \' → Panel \', p.connected_panel_id, \':\', p.connected_panel_port) as description\n            FROM ports p\n            JOIN switches s ON p.switch_id = s.id\n            WHERE p.connected_panel_id IS NOT NULL \n                AND p.connected_panel_port IS NOT NULL\n                AND NOT EXISTS (\n                    SELECT 1 FROM patch_ports pp \n                    WHERE pp.panel_id = p.connected_panel_id \n                        AND pp.port_number = p.connected_panel_port\n                        AND p.panel_type = \'patch\'\n                    UNION\n                    SELECT 1 FROM fiber_ports fp\n                    WHERE fp.panel_id = p.connected_panel_id \n                        AND fp.port_number = p.connected_panel_port\n                        AND p.panel_type = \'fiber\'\n                )\n            \n            UNION ALL\n            \n            -- Panel\'de switch var ama port\'ta yok\n            SELECT \n                \'panel_has_switch_but_port_missing\' as issue_type,\n                NULL as port_id,\n                pp.connected_switch_id as switch_id,\n                pp.connected_switch_port as port_no,\n                pp.panel_id as connected_panel_id,\n                pp.port_number as connected_panel_port,\n                \'patch\' as panel_type,\n                pp.id as panel_port_id,\n                CONCAT(\'Panel \', pp.panel_id, \':\', pp.port_number, \' → Switch \', pp.connected_switch_id, \':\', pp.connected_switch_port) as description\n            FROM patch_ports pp\n            WHERE pp.connected_switch_id IS NOT NULL \n                AND pp.connected_switch_port IS NOT NULL\n                AND NOT EXISTS (\n                    SELECT 1 FROM ports p \n                    WHERE p.switch_id = pp.connected_switch_id \n                        AND p.port_no = pp.connected_switch_port\n                        AND p.connected_panel_id = pp.panel_id\n                        AND p.connected_panel_port = pp.port_number\n                )\n            \n            UNION ALL\n            \n            -- Fiber panel\'de switch var ama port\'ta yok\n            SELECT \n                \'fiber_panel_has_switch_but_port_missing\' as issue_type,\n                NULL as port_id,\n                fp.connected_switch_id as switch_id,\n                fp.connected_switch_port as port_no,\n                fp.panel_id as connected_panel_id,\n                fp.port_number as connected_panel_port,\n                \'fiber\' as panel_type,\n                fp.id as panel_port_id,\n                CONCAT(\'Fiber Panel \', fp.panel_id, \':\', fp.port_number, \' → Switch \', fp.connected_switch_id, \':\', fp.connected_switch_port) as description\n            FROM fiber_ports fp\n            WHERE fp.connected_switch_id IS NOT NULL \n                AND fp.connected_switch_port IS NOT NULL\n                AND NOT EXISTS (\n                    SELECT 1 FROM ports p \n                    WHERE p.switch_id = fp.connected_switch_id \n                        AND p.port_no = fp.connected_switch_port\n                        AND p.connected_panel_id = fp.panel_id\n                        AND p.connected_panel_port = fp.port_number\n                )
